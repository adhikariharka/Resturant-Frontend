# ============================================================
# Harke — Restaurant Frontend (Next.js) environment template
# ============================================================
# Copy this file to `.env` (or `.env.local`) and fill in values.
# Any variable starting with NEXT_PUBLIC_ is exposed to the browser.
# ------------------------------------------------------------

# -------- Backend API --------
# Base URL of the NestJS API. Used by RTK Query, NextAuth, Socket.io.
NEXT_PUBLIC_API_URL=http://localhost:8000

# -------- NextAuth (required in production) --------
# Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET=change-me-to-a-random-string
# Public URL of this Next.js app (used for OAuth callbacks)
NEXTAUTH_URL=http://localhost:3000

# -------- Google OAuth --------
# Client ID of the Google OAuth app. Must match GOOGLE_CLIENT_ID on the backend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
